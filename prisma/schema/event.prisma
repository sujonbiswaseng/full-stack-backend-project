model Event {
  id           String   @id @default(uuid())
  title        String
  description  String
  date         DateTime
  time         String
  venue        String
  type         EventType
  fee          Float    @default(0)

  organizerId  String
  organizer    User     @relation("UserEvents", fields: [organizerId], references: [id])

  // relations
  participants Participant[]
  invitations  Invitation[]
  reviews      Review[]
  payments     Payment[]

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}