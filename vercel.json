{
  "version": 2,
  "builds": [
      {
          "src": "api/server.js",
          "use": "@vercel/node"
      }
  ],
  "routes": [
      {
          "src": "/(.*)",
          "dest": "/api/server.js"
      }
  ],
  "crons": [
    {
      "path": "/api/v1/cleanup",
      "schedule": "*/5 * * * *"
    }
  ]
}